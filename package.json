{
  "name": "sic-crystal-furnace",
  "version": "1.0.0",
  "description": "SiC 长晶炉热场模拟工业软件 - 2500°C 极高温热传导与辐射耦合仿真",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "webpack serve --config webpack.renderer.js --mode development",
    "dev:electron": "wait-on http://localhost:8080 && electron .",
    "build:renderer": "webpack --config webpack.renderer.js --mode production",
    "build:addon": "node-gyp rebuild",
    "build": "npm run build:addon && npm run build:renderer",
    "test:cpp": "cd native && mkdir -p build && cd build && cmake .. && cmake --build . && ctest --output-on-failure"
  },
  "keywords": ["SiC", "crystal-growth", "FEM", "thermal-simulation", "electron"],
  "author": "SIC Crystal Furnace Team",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.8.1",
    "electron": "^28.0.0",
    "html-webpack-plugin": "^5.5.3",
    "node-gyp": "^10.0.1",
    "style-loader": "^3.3.3",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "dependencies": {
    "bindings": "^1.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "node-addon-api": "^7.1.0"
  }
}
